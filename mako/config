anchor=bottom-center
default-timeout=2000
width=300
height=120
padding=15
font=JetBrainsMono Nerd Font 12
text-alignment=center

# --- Visual Improvements ---
border-radius=10
margin=10
layer=overlay
max-icon-size=48

# --- Functional Improvements ---
max-history=100
sort=-time
group-by=app-name
max-visible=3

# --- Interaction Bindings ---
on-button-left=invoke-default-action
on-button-middle=dismiss-all
on-button-right=dismiss

# --- Colors ---
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #313244

# --- Custom Criteria ---
[urgency=critical]
border-color=#fab387
default-timeout=0

[grouped]
format=<b>%s</b> (%g)\n%b
